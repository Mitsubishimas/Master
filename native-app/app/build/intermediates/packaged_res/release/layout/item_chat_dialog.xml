<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="12dp"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">
        
        <!-- Аватар -->
        <RelativeLayout
            android:layout_width="56dp"
            android:layout_height="56dp">
            <ImageView
                android:id="@+id/dialogAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/ic_avatar_placeholder"
                android:padding="12dp" />
            <View
                android:id="@+id/dialogOnlineDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/online_dot"
                android:layout_alignBottom="@id/dialogAvatar"
                android:layout_alignEnd="@id/dialogAvatar"
                android:visibility="gone" />
        </RelativeLayout>
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            
            <TextView
                android:id="@+id/dialogUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/dialogLastMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:layout_marginTop="4dp" />
                
        </LinearLayout>
        
        <TextView
            android:id="@+id/dialogUnread"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/unread_badge"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:gravity="center"
            android:visibility="gone" />
            
    </LinearLayout>
    
</androidx.cardview.widget.CardView>
